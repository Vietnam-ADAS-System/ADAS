# Mẫu cấu hình: copy file này thành .env rồi sửa theo máy.

# Môi trường chạy
APP_ENV=development
NODE_ENV=development
LOG_LEVEL=debug

# Cổng dịch vụ
FRONTEND_PORT=3000
NODE_SERVER_PORT=5000
AI_SERVICE_PORT=8000

# Địa chỉ dịch vụ
FRONTEND_URL=http://127.0.0.1:3000
NODE_SERVER_URL=http://127.0.0.1:5000
AI_SERVICE_URL=http://127.0.0.1:8000

# API frontend và CORS
REACT_APP_API_BASE_URL=http://127.0.0.1:5000
VITE_API_BASE_URL=http://127.0.0.1:5000
CORS_ORIGIN=http://127.0.0.1:3000

# Upload file
UPLOAD_DIR=backend/node-server/uploads
MAX_UPLOAD_SIZE_MB=500

# Cấu hình AI
AI_DEVICE=auto
AI_IMAGE_SIZE=640
AI_CONFIDENCE_THRESHOLD=0.25
AI_IOU_THRESHOLD=0.45
AI_TARGET_FPS=24

# Object Detection: xe hơi, xe máy, người đi bộ
# Ưu tiên accuracy: dùng model lớn (yolo26x.pt nếu môi trường hỗ trợ).
# Nếu bài/giảng viên yêu cầu YOLO11 thì đổi thành yolo11x.pt hoặc best.pt sau fine-tune.
VEHICLE_DETECTION_IMAGE_SIZE=960
VEHICLE_DETECTION_CONFIDENCE_THRESHOLD=0.35
VEHICLE_DETECTION_IOU_THRESHOLD=0.50
VEHICLE_DETECTION_TARGET_CLASSES=person,car,motorcycle
VEHICLE_DETECTION_AUGMENT=false
VEHICLE_DETECTION_PREPROCESS=false
VEHICLE_DETECTION_END2END=false

# Đường dẫn model
YOLO_VEHICLE_MODEL_PATH=yolo26x.pt
YOLO_SEGMENTATION_MODEL_PATH=yolo11n-seg.pt
TRAFFIC_SIGN_MODEL_PATH=backend/ai-service/ai_models/traffic_sign_detection/weights/best.pt
LANE_SEGMENTATION_MODEL_PATH=backend/ai-service/ai_models/lane_segmentation/weights/best.pth
DEEPSORT_MODEL_PATH=backend/ai-service/tracking/weights/ckpt.t7

# Thư mục dữ liệu và kết quả
DATASET_DIR=datasets
OUTPUT_DIR=outputs
PREDICTIONS_DIR=outputs/predictions
PROCESSED_VIDEOS_DIR=outputs/videos
SCREENSHOTS_DIR=outputs/screenshots
REPORTS_DIR=outputs/reports

# Lưu kết quả
SAVE_ANNOTATED_VIDEO=true
SAVE_FRAME_SCREENSHOTS=false

# Database / secret tùy chọn
DATABASE_URL=
JWT_SECRET=change-me
API_KEY=
