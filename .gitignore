# Vẫn cho phép ảnh trong tài liệu
!docs/**/*.jpg
!docs/**/*.jpeg
!docs/**/*.png
!docs/**/*.svg

# Dữ liệu dự án: chỉ giữ README và .gitkeep
datasets/**
!datasets/
!datasets/README.md
!datasets/**/
!datasets/**/.gitkeep

# Kết quả chạy hệ thống: chỉ giữ README và .gitkeep
outputs/**
!outputs/
!outputs/README.md
!outputs/**/
!outputs/**/.gitkeep

# File upload khi chạy backend
backend/node-server/uploads/*
!backend/node-server/uploads/.gitkeep


# Cho phép đẩy các thư mục 'weights' và file mô hình '.pt' trong tất cả các phân hệ AI
!backend/ai-service/ai_models/**/weights/
!backend/ai-service/ai_models/**/weights/*.pt

# Cho phép đẩy tất cả ảnh báo cáo kết quả trong các thư mục 'evaluation'
!backend/ai-service/ai_models/**/evaluation/**