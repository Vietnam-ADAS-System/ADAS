# File môi trường và khóa bí mật
.env
.env.*
!.env.example
!**/.env.example
*.key
*.pem
secrets/

# File hệ điều hành và trình soạn thảo
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Log và file tạm
